# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email Service
VITE_RESEND_API_KEY=re_your-api-key-here

# Admin Password Hash (use AUTH.hashPassword() to generate)
ADMIN_PASSWORD_HASH=your-hashed-password-here

# For local development, you can also set these in localStorage via browser console:
# localStorage.setItem('sb_url', 'your-url');
# localStorage.setItem('sb_key', 'your-key');
# localStorage.setItem('resend_key', 'your-resend-key');
