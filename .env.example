# Supabase Configuration (public - safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email Service (private - server-side only via Worker)
RESEND_API_KEY=re_your-api-key-here

# Admin Password Hash (use AUTH.hashPassword() to generate)
ADMIN_PASSWORD_HASH=your-hashed-password-here

# For local development with Supabase on browser:
# localStorage.setItem('sb_url', 'your-url');
# localStorage.setItem('sb_key', 'your-key');
# Resend key is handled server-side by Worker - no need to set locally
